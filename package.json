{
  "name": "@fangxinyan/lumina",
  "version": "0.6.3",
  "description": "Lumina — Neumorphic component library for Electron & React apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css",
    "./tokens": "./dist/tokens.css",
    "./llms.md": "./docs/llms.md",
    "./llms/*": "./docs/llms/*",
    "./package.json": "./package.json",
    "./TitleBar": {
      "types": "./dist/AppShell.d.ts",
      "import": "./dist/AppShell.js",
      "require": "./dist/AppShell.cjs"
    },
    "./WindowControls": {
      "types": "./dist/AppShell.d.ts",
      "import": "./dist/AppShell.js",
      "require": "./dist/AppShell.cjs"
    },
    "./Sidebar": {
      "types": "./dist/AppShell.d.ts",
      "import": "./dist/AppShell.js",
      "require": "./dist/AppShell.cjs"
    },
    "./StatusBarItem": {
      "types": "./dist/StatusBar.d.ts",
      "import": "./dist/StatusBar.js",
      "require": "./dist/StatusBar.cjs"
    },
    "./MessageContainer": {
      "types": "./dist/Message.d.ts",
      "import": "./dist/Message.js",
      "require": "./dist/Message.cjs"
    },
    "./message": {
      "types": "./dist/Message.d.ts",
      "import": "./dist/Message.js",
      "require": "./dist/Message.cjs"
    },
    "./ToastContainer": {
      "types": "./dist/Message.d.ts",
      "import": "./dist/Message.js",
      "require": "./dist/Message.cjs"
    },
    "./toast": {
      "types": "./dist/Message.d.ts",
      "import": "./dist/Message.js",
      "require": "./dist/Message.cjs"
    },
    "./ImageGrid": {
      "types": "./dist/Image.d.ts",
      "import": "./dist/Image.js",
      "require": "./dist/Image.cjs"
    },
    "./SpriteImage": {
      "types": "./dist/Image.d.ts",
      "import": "./dist/Image.js",
      "require": "./dist/Image.cjs"
    },
    "./LayeredImage": {
      "types": "./dist/Image.d.ts",
      "import": "./dist/Image.js",
      "require": "./dist/Image.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist",
    "docs/llms.md",
    "docs/llms",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "gen:docs": "node scripts/gen-llms-doc.mjs",
    "verify:public-api": "node scripts/verify-public-api.mjs",
    "prepublishOnly": "npm run typecheck && npm run gen:docs && npm run build:lib && npm run verify:public-api"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@babel/standalone": "^7.29.2",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "postcss": "^8.5.10",
    "postcss-import": "^16.1.1",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "keywords": [
    "react",
    "ui",
    "component-library",
    "neumorphism",
    "electron",
    "typescript",
    "lumina"
  ],
  "author": "fangxinyan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LHorTL/lumina.git"
  },
  "homepage": "https://github.com/LHorTL/lumina#readme",
  "bugs": {
    "url": "https://github.com/LHorTL/lumina/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
