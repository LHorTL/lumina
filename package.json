{
  "name": "@fangxinyan/lumina",
  "version": "0.1.3",
  "description": "Lumina — Neumorphic component library for Electron & React apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css",
    "./tokens": "./dist/tokens.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "postcss": "^8.5.10",
    "postcss-import": "^16.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "keywords": [
    "react",
    "ui",
    "component-library",
    "neumorphism",
    "electron",
    "typescript",
    "lumina"
  ],
  "author": "fangxinyan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LHorTL/lumina.git"
  },
  "homepage": "https://github.com/LHorTL/lumina#readme",
  "bugs": {
    "url": "https://github.com/LHorTL/lumina/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
